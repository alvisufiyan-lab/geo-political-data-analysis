   "source": [
    "# ── Step 1: Crosswalk ─────────────────────────────────────────────────────\n",
    "name_map = {\n",
    "    'Bosnia-Herzegovina'                              : 'Bosnia and Herzegovina',\n",
    "    'Cambodia (Kampuchea)'                            : 'Cambodia',\n",
    "    'China'                                           : \"China, People's Republic of\",\n",
    "    'Congo'                                           : 'Congo, Republic of ',\n",
    "    'DR Congo (Zaire)'                                : 'Congo, Dem. Rep. of the',\n",
    "    'Gambia'                                          : 'Gambia, The',\n",
    "    'Ivory Coast'                                     : \"Côte d'Ivoire\",\n",
    "    'Kyrgyzstan'                                      : 'Kyrgyz Republic',\n",
    "    'Laos'                                            : 'Lao P.D.R.',\n",
    "    'Myanmar (Burma)'                                 : 'Myanmar',\n",
    "    'North Korea'                                     : \"Korea, Dem. People's Rep.\",\n",
    "    'North Macedonia'                                 : 'North Macedonia ',\n",
    "    'Russia (Soviet Union)'                           : 'Russian Federation',\n",
    "    'Serbia (Yugoslavia)'                             : 'Serbia',\n",
    "    'South Sudan'                                     : 'South Sudan, Republic of',\n",
    "    'South Vietnam'                                   : 'Vietnam',\n",
    "    'South Yemen'                                     : 'Yemen',\n",
    "    'Turkey'                                          : 'Türkiye, Republic of',\n",
    "    'United States of America'                        : 'United States',\n",
    "    'Yemen (North Yemen)'                             : 'Yemen',\n",
    "    'Zimbabwe (Rhodesia)'                             : 'Zimbabwe',\n",
    "}\n",
    "\n",
    "# ── Step 2: Expand conflict → one row per country-year ────────────────────\n",
    "conflict_rows = []\n",
    "for _, row in d2.iterrows():\n",
    "\n",
    "    # Extract and map country name directly inside the loop — no prior step needed\n",
    "    raw     = row[\"side_a\"].replace(\"Government of \", \"\").strip()\n",
    "    country = name_map.get(raw, raw)           # apply crosswalk, keep original if no match\n",
    "\n",
    "    for yr in range(int(row[\"start_year\"]), int(row[\"end_year\"]) + 1):\n",
    "        conflict_rows.append({\n",
    "            \"country_name\"    : country,\n",
    "            \"Year\"            : yr,\n",
    "            \"side_b\"          : row[\"side_b\"],\n",
    "            \"region\"          : row[\"region\"],\n",
    "            \"intensity_level\" : row[\"intensity_level\"]\n",
    "        })\n",
    "\n",
    "conf_expanded = pd.DataFrame(conflict_rows)\n",
    "\n",
    "# ── Step 3: Aggregate multiple conflicts in same country-year ─────────────\n",
    "conf_agg = (\n",
    "    conf_expanded\n",
    "    .groupby([\"country_name\", \"Year\"])\n",
    "    .agg(\n",
    "        side_b          = (\"side_b\",         lambda x: \" | \".join(x.dropna().unique())),\n",
    "        region          = (\"region\",          lambda x: \" | \".join(x.dropna().unique())),\n",
    "        intensity_level = (\"intensity_level\", \"max\")\n",
    "    )\n",
    "    .reset_index()\n",
    ")\n",
    "\n",
    "# # ── Step 4: Flag in_conflict on GDP dataset ───────────────────────────────\n",
    "conflict_set = set(zip(conf_agg[\"country_name\"], conf_agg[\"Year\"]))\n",
    "\n",
    "d1[\"in_conflict\"] = d1.apply(\n",
    "    lambda r: (r[\"country_name\"], r[\"Year\"]) in conflict_set, axis=1\n",
    ")\n",
    "\n",
    "# # ── Step 5: Join conflict details onto GDP ────────────────────────────────\n",
    "merged = pd.merge(d1, conf_agg, on=[\"country_name\", \"Year\"], how=\"left\")\n",
    "print(merged.sample(5))"
   ]
  },
